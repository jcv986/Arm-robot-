/**
 * Task 5: same scenario again, but the MotorController is constructed
 * with PriorityMode.CEILING and a ceiling priority of Thread.MAX_PRIORITY.
 * Whichever thread acquires the resource is immediately raised to the
 * ceiling priority for as long as it holds it, so Logger is protected
 * from MotionPlanner's CPU-bound work from the moment it acquires the
 * resource - priority inversion should not occur at all here.
 */
public class Task5_PriorityCeilingDemo {
    public static void main(String[] args) throws Exception {
        EventLogger logger = new EventLogger("task5_log.csv");
        MotorController controller =
                new MotorController(MotorController.PriorityMode.CEILING, Thread.MAX_PRIORITY, logger);

        LoggerThread lowLogger = new LoggerThread(controller, 0, 4000, 1, logger, true);
        SafetyMonitorThread highSafety = new SafetyMonitorThread(controller, 0, 200, 1, logger, false);
        CpuLoadThread mediumPlanner = new CpuLoadThread("MotionPlanner", Thread.NORM_PRIORITY, 3500, logger);

        lowLogger.start();
        Thread.sleep(300);
        highSafety.start();
        Thread.sleep(500);
        mediumPlanner.start();

        lowLogger.join();
        highSafety.join();
        mediumPlanner.join();

        logger.log("RESULT: SafetyMonitor waited " + highSafety.getLastWaitMillis()
                + " ms for the MotorController (priority ceiling enabled).");
        logger.close();
    }
}
